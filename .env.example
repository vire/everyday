# ── Repository ───────────────────────────────────────────────────────────────
TARGET_REPO=owner/name
GITHUB_LOGIN=           # optional — defaults to the result of `gh api user`

# ── GitHub token ─────────────────────────────────────────────────────────────
# A Personal Access Token (classic or fine-grained) with at least:
#   repo    — read access to the target repository (PRs, CI runs, commits)
#   gist    — read/write access for the memory gist
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Model provider ───────────────────────────────────────────────────────────
# Set EITHER your own OpenAI key OR an OpenRouter key. agent/agent.ts picks the
# provider by which one is present: if OPENAI_API_KEY is set it talks to OpenAI
# directly, otherwise it falls back to OpenRouter.

# OpenAI (your own key) — talks to api.openai.com directly. Leave unset to use OpenRouter.
OPENAI_API_KEY=
# OpenAI model slug (no provider prefix). Avoid *-codex slugs: they enforce strict
# function-call schemas and reject this agent's tool definitions.
OPENAI_MODEL=gpt-5-nano

# OpenRouter (used only when OPENAI_API_KEY is unset).
# Note: @openrouter/ai-sdk-provider requires ai@^6 and is incompatible with
# the ai@7.x beta pinned in this project — hence the generic compatible provider.
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Any OpenRouter model slug. Avoid the *-codex models (same reason as above).
OPENROUTER_MODEL=openai/gpt-5-nano

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token from a Slack app with chat:write scope. Create at api.slack.com/apps.
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0XXXXXXX
