# ── Repository ───────────────────────────────────────────────────────────────
# One or more repos, comma-delimited (owner/name). Each gets its own digest
# section and its own memory file. A single value works unchanged.
#   TARGET_REPO=octocat/hello-world
#   TARGET_REPO=octocat/hello-world,acme/widgets
TARGET_REPO=owner/name
GITHUB_LOGIN=           # optional — defaults to the result of `gh api user`

# ── GitHub token ─────────────────────────────────────────────────────────────
# A Personal Access Token (classic or fine-grained) with read access to the
# target repos — commits, PRs, and CI runs:
#   classic:       repo scope
#   fine-grained:  Contents + Pull requests + Actions = Read (Metadata is implied)
# No gist scope needed — memory is a local file on the eve-memory volume.
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Model provider ───────────────────────────────────────────────────────────
# OpenAI takes preference, but ONLY when BOTH OPENAI_API_KEY and OPENAI_MODEL are
# set — then agent/agent.ts talks to api.openai.com directly. If either is empty,
# it falls back to OpenRouter (set OPENROUTER_API_KEY below). See agent/lib/model.ts.

# OpenAI (your own key) — talks to api.openai.com directly. Requires OPENAI_MODEL too.
OPENAI_API_KEY=
# OpenAI model slug (no provider prefix). REQUIRED to use OpenAI — leave empty to
# stay on OpenRouter. Avoid *-codex slugs: they enforce strict function-call
# schemas and reject this agent's tool definitions.
OPENAI_MODEL=gpt-5-nano

# OpenRouter (used only when OPENAI_API_KEY is unset).
# Note: @openrouter/ai-sdk-provider requires ai@^6 and is incompatible with
# the ai@7.x beta pinned in this project — hence the generic compatible provider.
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Any OpenRouter model slug. Avoid the *-codex models (same reason as above).
OPENROUTER_MODEL=openai/gpt-5-nano

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token from a Slack app with chat:write scope. Create at api.slack.com/apps.
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0XXXXXXX

# ── Session logging (agent/hooks/session-logger.ts) ──────────────────────────
# Every runtime event is written to date-stamped files for inspection:
#   sessions-YYYY-MM-DD.log     human-readable, one line per event (grep-friendly)
#   sessions-YYYY-MM-DD.ndjson  full events, consumable by scripts/helpers.sh
# Readable lines also mirror to stdout (Coolify's log viewer). Defaults to
# /app/logs in production (persisted on the eve-logs volume), ./logs locally.
EVE_LOG_DIR=
# Set to 0 to silence the stdout mirror, or skip the .ndjson sink, respectively.
EVE_LOG_STDOUT=1
EVE_LOG_JSON=1

# ── Memory (agent/lib/memory.ts) ─────────────────────────────────────────────
# Per-repo digest memory (CI baselines, open suggestions) is stored as one
# markdown file per repo: memory-<owner>-<name>.md. Defaults to /app/memory in
# production (persisted on the eve-memory volume), ./memory locally.
EVE_MEMORY_DIR=
